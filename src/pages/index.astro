---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { eighthWallProjects, resources } from '../data/projects';
---

<Layout>
  <header>
    <div class="header-inner">
      <a href="/" class="header-brand">evanmcarlson.github.io</a>
      <nav class="header-nav">
        <div class="header-icons">
          <a href="https://github.com/evanmcarlson" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <i class="fab fa-github"></i>
          </a>
          <a href="https://www.linkedin.com/in/evanmcarlson" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <i class="fab fa-linkedin"></i>
          </a>
        </div>
        <button id="theme-toggle" aria-label="Toggle theme">
          <i id="theme-icon" class="fas fa-sun"></i>
        </button>
      </nav>
    </div>
  </header>

  <main>
    <section id="projects" class="section">
      <h2 class="section-title">8th Wall Projects</h2>
      <div class="card-grid">
        {eighthWallProjects.map((project) => <Card {...project} />)}
      </div>
    </section>

    <section id="resources" class="section">
      <h2 class="section-title">Resources</h2>
      <div class="card-grid">
        {resources.map((project) => <Card {...project} />)}
      </div>
    </section>
  </main>

  <footer>
    <p><a href="https://github.com/evanmcarlson">github.com/evanmcarlson</a></p>
  </footer>
</Layout>
